{
  "name": "mediarr",
  "version": "1.0.0",
  "description": "Mediarr is a unified, all-in-one media management powerhouse designed to replace the fragmented \"arr\" stack (Sonarr, Radarr, Bazarr, Prowlarr) with a single, modern interface and a high-performance integrated backend.",
  "main": "index.js",
  "scripts": {
    "start:app": "npm run start --workspace=app",
    "start:api": "tsx server/src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "workspaces": [
    "app",
    "server"
  ],
  "private": "true",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.2",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.3.0",
