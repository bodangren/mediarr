{
  "name": "mediarr",
  "version": "1.0.0",
  "description": "Mediarr is a unified, all-in-one media management powerhouse designed to replace the fragmented \"arr\" stack (Sonarr, Radarr, Bazarr, Prowlarr) with a single, modern interface and a high-performance integrated backend.",
  "main": "index.js",
  "scripts": {
    "start:app": "npm run start --workspace=app",
    "start:api": "tsx server/src/main.ts",
    "dev": "DATABASE_URL=\"file:$(pwd)/mediarr.db\" API_PORT=3001 ENCRYPTION_KEY=dev-local-encryption-key DEFINITIONS_PATH=\"$(pwd)/server/definitions\" npm run dev --workspace=server & DATABASE_URL=\"file:$(pwd)/mediarr.db\" API_INTERNAL_URL=http://localhost:3001 npm run dev --workspace=app",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cardigann:live": "CARDIGANN_LIVE_TESTS=true vitest run server/src/indexers/cardigann-conformance/liveSiteDefinitions.test.ts server/src/indexers/cardigann-conformance/liveReleaseSearch.test.ts",
    "test:cardigann:live:search": "CARDIGANN_LIVE_TESTS=true vitest run server/src/indexers/cardigann-conformance/liveReleaseSearch.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "workspaces": [
    "app",
    "server"
  ],
  "private": "true",
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^6.7.0",
    "@prisma/client": "^6.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.2",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^11.9.0",
    "prisma": "^6.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@tanstack/react-virtual": "^3.13.18",
    "bonjour-service": "^1.3.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.3.5",
    "fastify": "^5.6.1",
    "js-yaml": "^4.1.1",
    "linkedom": "^0.18.12",
    "node-cron": "^4.2.1",
    "webtorrent": "^2.8.5",
    "zod": "^3.25.76"
  }
}
