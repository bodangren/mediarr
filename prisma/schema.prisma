// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MediaType {
  TV
  MOVIE
}

enum VariantMediaType {
  EPISODE
  MOVIE
}

enum SubtitleTrackSource {
  EMBEDDED
  EXTERNAL
}

enum WantedSubtitleState {
  PENDING
  SEARCHING
  DOWNLOADED
  FAILED
}

enum ActivityEventType {
  MEDIA_ADDED
  SEARCH_EXECUTED
  RELEASE_GRABBED
  IMPORT_COMPLETED
  SUBTITLE_DOWNLOADED
  INDEXER_TESTED
}

model Media {
  id                  Int            @id @default(autoincrement())
  mediaType           MediaType
  tmdbId              Int?
  tvdbId              Int?
  imdbId              String?        @unique
  title               String
  cleanTitle          String
  sortTitle           String
  status              String
  overview            String?
  monitored           Boolean        @default(true)
  qualityProfileId    Int
  qualityProfile      QualityProfile @relation(fields: [qualityProfileId], references: [id])
  path                String?
  year                Int
  added               DateTime       @default(now())
  availability        String?
  minimumAvailability String?
  inCinemas           DateTime?
  digitalRelease      DateTime?
  physicalRelease     DateTime?
  network             String?
  series              Series?
  movie               Movie?

  @@unique([mediaType, tmdbId])
  @@unique([mediaType, tvdbId])
}

model Series {
  id               Int            @id @default(autoincrement())
  mediaId          Int?           @unique
  tvdbId           Int            @unique
  tmdbId           Int?           @unique
  imdbId           String?        @unique
  title            String
  cleanTitle       String
  sortTitle        String
  status           String // e.g., continuing, ended
  overview         String?
  monitored        Boolean        @default(true)
  qualityProfileId Int
  qualityProfile   QualityProfile @relation(fields: [qualityProfileId], references: [id])
  path             String?
  year             Int
  network          String?
  added            DateTime       @default(now())
  media            Media?         @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  seasons          Season[]
  episodes         Episode[]
}

model Season {
  id           Int       @id @default(autoincrement())
  seriesId     Int
  seasonNumber Int
  monitored    Boolean   @default(true)
  series       Series    @relation(fields: [seriesId], references: [id])
  episodes     Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id            Int                @id @default(autoincrement())
  seriesId      Int
  seasonId      Int?
  tvdbId        Int                @unique
  seasonNumber  Int
  episodeNumber Int
  title         String
  airDateUtc    DateTime?
  overview      String?
  monitored     Boolean            @default(true)
  path          String?
  series        Series             @relation(fields: [seriesId], references: [id])
  season        Season?            @relation(fields: [seasonId], references: [id])
  fileVariants  MediaFileVariant[]
}

model Movie {
  id                  Int                @id @default(autoincrement())
  mediaId             Int?               @unique
  tmdbId              Int                @unique
  imdbId              String?            @unique
  title               String
  cleanTitle          String
  sortTitle           String
  status              String
  overview            String?
  monitored           Boolean            @default(true)
  qualityProfileId    Int
  qualityProfile      QualityProfile     @relation(fields: [qualityProfileId], references: [id])
  languageProfileId   Int?
  path                String?
  year                Int
  added               DateTime           @default(now())
  minimumAvailability String?
  inCinemas           DateTime?
  digitalRelease      DateTime?
  physicalRelease     DateTime?
  collectionId        Int?
  collection          Collection?        @relation(fields: [collectionId], references: [id])
  media               Media?             @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  fileVariants        MediaFileVariant[]
}

model MediaFileVariant {
  id                Int                      @id @default(autoincrement())
  mediaType         VariantMediaType
  movieId           Int?
  episodeId         Int?
  path              String
  fileSize          BigInt
  monitored         Boolean                  @default(true)
  probeFingerprint  String?
  releaseName       String?
  quality           String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  movie             Movie?                   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode           Episode?                 @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  audioTracks       VariantAudioTrack[]
  subtitleTracks    VariantSubtitleTrack[]
  missingSubtitles  VariantMissingSubtitle[]
  wantedSubtitles   WantedSubtitle[]
  subtitleHistories SubtitleHistory[]

  @@unique([mediaType, path])
  @@index([movieId])
  @@index([episodeId])
}

model VariantMissingSubtitle {
  id           Int              @id @default(autoincrement())
  variantId    Int
  languageCode String
  isForced     Boolean          @default(false)
  isHi         Boolean          @default(false)
  createdAt    DateTime         @default(now())
  variant      MediaFileVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, languageCode, isForced, isHi])
  @@index([variantId])
}

model VariantAudioTrack {
  id           Int              @id @default(autoincrement())
  variantId    Int
  streamIndex  Int
  languageCode String?
  codec        String?
  channels     String?
  isDefault    Boolean          @default(false)
  isForced     Boolean          @default(false)
  isCommentary Boolean          @default(false)
  name         String?
  variant      MediaFileVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, streamIndex])
  @@index([languageCode])
}

model VariantSubtitleTrack {
  id           Int                 @id @default(autoincrement())
  variantId    Int
  source       SubtitleTrackSource
  streamIndex  Int?
  languageCode String?
  isForced     Boolean             @default(false)
  isHi         Boolean             @default(false)
  codec        String?
  filePath     String?
  fileSize     BigInt?
  variant      MediaFileVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([languageCode])
}

model WantedSubtitle {
  id           Int                 @id @default(autoincrement())
  variantId    Int
  languageCode String
  isForced     Boolean             @default(false)
  isHi         Boolean             @default(false)
  state        WantedSubtitleState @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  variant      MediaFileVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  history      SubtitleHistory[]

  @@unique([variantId, languageCode, isForced, isHi])
  @@index([state])
}

model SubtitleHistory {
  id               Int              @id @default(autoincrement())
  variantId        Int
  wantedSubtitleId Int?
  languageCode     String
  provider         String?
  score            Float?
  storedPath       String?
  message          String?
  createdAt        DateTime         @default(now())
  variant          MediaFileVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  wantedSubtitle   WantedSubtitle?  @relation(fields: [wantedSubtitleId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([wantedSubtitleId])
}

model QualityProfile {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique
  cutoff              Int                   @default(0)
  items               Json                  @default("[]")
  languageProfileId   Int?
  medias              Media[]
  series              Series[]
  movies              Movie[]
  collections         Collection[]
  customFormatScores  CustomFormatScore[]
  importLists         ImportList[]
}

model Collection {
  id                      Int       @id @default(autoincrement())
  tmdbCollectionId        Int       @unique
  name                    String
  overview                String?
  posterPath              String?
  backdropPath            String?
  monitored               Boolean   @default(false)
  qualityProfileId        Int?
  rootFolderPath          String?
  addMoviesAutomatically  Boolean   @default(false)
  searchOnAdd             Boolean   @default(false)
  minimumAvailability     String    @default("released")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  qualityProfile          QualityProfile?  @relation(fields: [qualityProfileId], references: [id])
  movies                  Movie[]
}

model ImportList {
  id                Int       @id @default(autoincrement())
  name              String
  providerType      String    // 'tmdb-popular', 'tmdb-list', etc.
  config            Json      // Provider-specific config
  rootFolderPath    String
  qualityProfileId  Int
  languageProfileId Int?      // For Bazarr integration
  monitorType       String    // 'movie', 'collection', etc.
  enabled           Boolean   @default(true)
  syncInterval      Int       @default(24) // hours
  lastSyncAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  qualityProfile    QualityProfile @relation(fields: [qualityProfileId], references: [id])
  exclusions        ImportListExclusion[]

  @@index([enabled])
}

model ImportListExclusion {
  id           Int        @id @default(autoincrement())
  importListId Int?
  tmdbId       Int?
  imdbId       String?
  tvdbId       Int?
  title        String
  createdAt    DateTime   @default(now())
  importList   ImportList? @relation(fields: [importListId], references: [id], onDelete: Cascade)

  @@unique([tmdbId, imdbId, tvdbId])
  @@index([tmdbId])
  @@index([importListId])
}

model CustomFilter {
  id         Int      @id @default(autoincrement())
  name       String
  type       String
  conditions Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, type])
  @@index([type])
}

model CustomFormat {
  id                             Int                   @id @default(autoincrement())
  name                           String                @unique
  includeCustomFormatWhenRenaming Boolean              @default(false)
  conditions                     Json                  // Array of condition objects
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt
  scores                         CustomFormatScore[]
}

model CustomFormatScore {
  id                Int            @id @default(autoincrement())
  customFormatId    Int
  qualityProfileId  Int
  score             Int            @default(0)
  customFormat      CustomFormat   @relation(fields: [customFormatId], references: [id], onDelete: Cascade)
  qualityProfile    QualityProfile @relation(fields: [qualityProfileId], references: [id], onDelete: Cascade)

  @@unique([customFormatId, qualityProfileId])
}

model QualityDefinition {
  id         Int    @id
  name       String
  source     String
  resolution Int    @default(0)
  title      String?
  weight     Int    @default(0)
}

model Indexer {
  id                  Int              @id @default(autoincrement())
  name                String           @unique
  implementation      String
  configContract      String
  settings            String // JSON string
  protocol            String // e.g., torrent, usenet
  supportedMediaTypes String           @default("[]") // JSON string array e.g., ["TV", "MOVIE"]
  enabled             Boolean          @default(true)
  supportsRss         Boolean          @default(false)
  supportsSearch      Boolean          @default(false)
  priority            Int              @default(25)
  added               DateTime         @default(now())
  releases            IndexerRelease[]
  healthSnapshot      IndexerHealthSnapshot?
}


model Proxy {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String
  hostname  String
  port      Int
  username  String?
  password  String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IndexerCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  minSize     Int?
  maxSize     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IndexerRelease {
  id           Int      @id @default(autoincrement())
  guid         String   @unique
  indexerId    Int
  indexer      Indexer  @relation(fields: [indexerId], references: [id])
  title        String
  size         BigInt?
  downloadUrl  String?
  infoUrl      String?
  magnetUrl    String?
  publishDate  DateTime
  seeders      Int?
  leechers     Int?
  protocol     String // torrent, usenet
  categories   String // JSON array of category IDs
  indexerFlags String? // comma-separated or JSON
  added        DateTime @default(now())
}

model Category {
  id Int @id // Using standard IDs (e.g., 2000 for Movies)

  name String

  parent_id Int?
}

model Torrent {
  id Int @id @default(autoincrement())

  infoHash String @unique

  name String

  status String // downloading, seeding, paused, stopped, error

  progress Float @default(0)

  downloadSpeed Float @default(0)

  uploadSpeed Float @default(0)

  eta Int? // seconds

  size BigInt

  downloaded BigInt @default(0)

  uploaded BigInt @default(0)

  ratio Float @default(0)

  path String // The internal path (/downloads/incomplete or /downloads/complete)

  added DateTime @default(now())

  completedAt DateTime?

  stopAtRatio Float?

  stopAtTime Int? // minutes

  magnetUrl String?

  torrentFile Bytes?

  peers TorrentPeer[]
}

model TorrentPeer {
  id Int @id @default(autoincrement())

  torrentId Int

  torrent Torrent @relation(fields: [torrentId], references: [id], onDelete: Cascade)

  ip String

  port Int

  client String?
}

model AppSettings {
  id                 Int      @id @default(1)
  torrentLimits      Json
  schedulerIntervals Json
  pathVisibility     Json
  apiKeys            Json?
  host               Json?
  security           Json?
  logging            Json?
  update             Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model IndexerHealthSnapshot {
  id               Int      @id @default(autoincrement())
  indexerId        Int      @unique
  indexer          Indexer  @relation(fields: [indexerId], references: [id], onDelete: Cascade)
  lastSuccessAt    DateTime?
  lastFailureAt    DateTime?
  failureCount     Int      @default(0)
  lastErrorMessage String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ActivityEvent {
  id           Int               @id @default(autoincrement())
  eventType    ActivityEventType
  sourceModule String
  entityRef    String?
  summary      String
  success      Boolean
  details      Json?
  occurredAt   DateTime          @default(now())
  createdAt    DateTime          @default(now())

  @@index([eventType, occurredAt])
  @@index([sourceModule, occurredAt])
  @@index([entityRef])
  @@index([success, occurredAt])
}

model Notification {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  type           String   // discord, email, telegram, slack, gotify, pushover, webhook
  enabled        Boolean  @default(true)
  onGrab         Boolean  @default(false)
  onDownload     Boolean  @default(false)
  onUpgrade      Boolean  @default(false)
  onRename       Boolean  @default(false)
  onSeriesAdd    Boolean  @default(false)
  onEpisodeDelete Boolean @default(false)
  config         Json     // Type-specific configuration (encrypted fields handled at app layer)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DownloadClient {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  protocol  String   // 'torrent' or 'usenet'
  type      String   // 'qbittorrent', 'transmission', 'deluge', 'rtorrent', 'utorrent', 'sabnzbd', 'nzbget'
  enabled   Boolean  @default(true)
  priority  Int      @default(25)
  config    String   // JSON string containing connection config (encrypted sensitive fields)
  added     DateTime @default(now())

  @@index([protocol])
  @@index([enabled])
}

model Blocklist {
  id            Int      @id @default(autoincrement())
  seriesId      Int?
  seriesTitle   String
  episodeId     Int?
  seasonNumber  Int?
  episodeNumber Int?
  releaseTitle  String
  quality       String?
  indexer       String?
  size          BigInt?
  reason        String
  dateBlocked   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([seriesId])
  @@index([dateBlocked])
}
