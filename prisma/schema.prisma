// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MediaType {
  TV
  MOVIE
}

model Media {
  id                  Int            @id @default(autoincrement())
  mediaType           MediaType
  tmdbId              Int?
  tvdbId              Int?
  imdbId              String?        @unique
  title               String
  cleanTitle          String
  sortTitle           String
  status              String
  overview            String?
  monitored           Boolean        @default(true)
  qualityProfileId    Int
  qualityProfile      QualityProfile @relation(fields: [qualityProfileId], references: [id])
  path                String?
  year                Int
  added               DateTime       @default(now())
  availability        String?
  minimumAvailability String?
  inCinemas           DateTime?
  digitalRelease      DateTime?
  physicalRelease     DateTime?
  network             String?
  series              Series?
  movie               Movie?

  @@unique([mediaType, tmdbId])
  @@unique([mediaType, tvdbId])
}

model Series {
  id               Int       @id @default(autoincrement())
  mediaId           Int?      @unique
  tvdbId           Int       @unique
  tmdbId           Int?      @unique
  imdbId           String?   @unique
  title            String
  cleanTitle       String
  sortTitle        String
  status           String    // e.g., continuing, ended
  overview         String?
  monitored        Boolean   @default(true)
  qualityProfileId Int
  qualityProfile   QualityProfile @relation(fields: [qualityProfileId], references: [id])
  path             String?
  year             Int
  network          String?
  added            DateTime  @default(now())
  media            Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  seasons          Season[]
  episodes         Episode[]
}

model Season {
  id           Int       @id @default(autoincrement())
  seriesId     Int
  seasonNumber Int
  monitored    Boolean   @default(true)
  series       Series    @relation(fields: [seriesId], references: [id])
  episodes     Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id               Int      @id @default(autoincrement())
  seriesId         Int
  seasonId         Int?
  tvdbId           Int      @unique
  seasonNumber     Int
  episodeNumber    Int
  title            String
  airDateUtc       DateTime?
  overview         String?
  monitored        Boolean  @default(true)
  series           Series   @relation(fields: [seriesId], references: [id])
  season           Season?  @relation(fields: [seasonId], references: [id])
}

model Movie {
  id               Int      @id @default(autoincrement())
  mediaId          Int?     @unique
  tmdbId           Int      @unique
  imdbId           String?  @unique
  title            String
  cleanTitle       String
  sortTitle        String
  status           String
  overview         String?
  monitored        Boolean  @default(true)
  qualityProfileId Int
  qualityProfile   QualityProfile @relation(fields: [qualityProfileId], references: [id])
  path             String?
  year             Int
  added            DateTime @default(now())
  minimumAvailability String?
  inCinemas        DateTime?
  digitalRelease   DateTime?
  physicalRelease  DateTime?
  media            Media?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
}

model QualityProfile {
  id     Int      @id @default(autoincrement())
  name   String   @unique
  medias Media[]
  series Series[]
  movies Movie[]
}

model Indexer {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  implementation String
  configContract String
  settings       String           // JSON string
  protocol       String           // e.g., torrent, usenet
  enabled        Boolean          @default(true)
  supportsRss    Boolean          @default(false)
  supportsSearch Boolean          @default(false)
  priority       Int              @default(25)
  added          DateTime         @default(now())
  releases       IndexerRelease[]
}

model IndexerRelease {
  id           Int      @id @default(autoincrement())
  guid         String   @unique
  indexerId    Int
  indexer      Indexer  @relation(fields: [indexerId], references: [id])
  title        String
  size         BigInt?
  downloadUrl  String?
  infoUrl      String?
  magnetUrl    String?
  publishDate  DateTime
  seeders      Int?
  leechers     Int?
  protocol     String   // torrent, usenet
  categories   String   // JSON array of category IDs
  indexerFlags String?  // comma-separated or JSON
  added        DateTime @default(now())
}

model Category {

  id        Int    @id // Using standard IDs (e.g., 2000 for Movies)

  name      String

  parent_id Int?

}



model Torrent {

  id             Int           @id @default(autoincrement())

  infoHash       String        @unique

  name           String

  status         String        // downloading, seeding, paused, stopped, error

  progress       Float         @default(0)

  downloadSpeed  Float         @default(0)

  uploadSpeed    Float         @default(0)

  eta            Int?          // seconds

  size           BigInt

  downloaded     BigInt        @default(0)

  uploaded       BigInt        @default(0)

  ratio          Float         @default(0)

  path           String        // The internal path (/downloads/incomplete or /downloads/complete)

  added          DateTime      @default(now())

  completedAt    DateTime?

  stopAtRatio    Float?

  stopAtTime     Int?          // minutes

  magnetUrl      String?

  torrentFile    Bytes?

  peers          TorrentPeer[]

}



model TorrentPeer {

  id        Int     @id @default(autoincrement())

  torrentId Int

  torrent   Torrent @relation(fields: [torrentId], references: [id], onDelete: Cascade)

  ip        String

  port      Int

  client    String?

}
